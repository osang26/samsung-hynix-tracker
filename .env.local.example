# 이 파일을 복사해서 ".env.local" 파일을 만들고, 아래에 본인(보호자) KIS 앱키를 넣으세요.
# .env.local 은 절대 GitHub에 올리지 마세요! (.gitignore에 이미 막혀 있습니다)

KIS_APP_KEY=여기에_앱키
KIS_APP_SECRET=여기에_앱시크릿

# 실전 계좌: https://openapi.koreainvestment.com:9443
# 모의 계좌: https://openapivts.koreainvestment.com:29443
KIS_BASE=https://openapi.koreainvestment.com:9443

# (선택) 저장소 — Upstash Redis. 차트·재무·뉴스를 받아 저장해두고 페이지는 저장소만 읽습니다.
#   없으면 자동으로 KIS 직접 호출로 동작합니다(로컬에선 없어도 됨). 배포 시 권장.
#   https://console.upstash.com 에서 Redis 만들고 REST URL/TOKEN 복사.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# (선택) 크론 보호용 비밀값(아무 문자열). Vercel Cron이 이 값으로 인증합니다.
CRON_SECRET=
